# Zammad MCP Server Configuration

# Zammad instance URL (required)
ZAMMAD_URL=https://your-instance.zammad.com/api/v1

# Authentication - choose one of the following methods:

# Option 1: API Token (recommended)
ZAMMAD_HTTP_TOKEN=your-api-token-here

# Option 2: OAuth2 Token
# ZAMMAD_OAUTH2_TOKEN=your-oauth2-token-here

# Option 3: Username and Password
# ZAMMAD_USERNAME=your-username
# ZAMMAD_PASSWORD=your-password

# === PII Filtering ===

# Enable PII anonymization (default: false)
# PII_FILTER_ENABLED=true

# Path to a text file with product/brand names to never anonymize.
# One name per line; lines starting with # are treated as comments.
# Defaults to mcp_zammad/product_names.txt (bundled in the repo).
# PII_PRODUCT_NAMES_FILE=/path/to/custom-product-names.txt

# Quick overrides: comma-separated product names (merged with the file above).
# PII_PRODUCT_NAMES=FLIMbee,SepiaII,VarPSF,2k SPAD

# How often (seconds) to refresh the known-persons list from Zammad (default: 1800)
# PII_REFRESH_INTERVAL=1800

# Optional: Logging level (default: INFO)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# === Transport Configuration ===

# Transport type: stdio (default) or http
# MCP_TRANSPORT=stdio

# HTTP Transport Settings (required if MCP_TRANSPORT=http)
# Host to bind to (default: 127.0.0.1)
# MCP_HOST=127.0.0.1

# Port to listen on (required for HTTP transport)
# MCP_PORT=8000
